@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="split-layout">
    <div class="right-side">
        <img src="/images/piwonka.png" alt="Bild" />
    </div>
    <div class="left-side">
        <h1>PIWONKA</h1>
    </div>
   
</div>

<style>
    body, html {
        margin: 0;
        padding: 0;
        height: 100%;
        font-family: 'Segoe UI', sans-serif;
    }

    .split-layout {
        display: flex;
        height: 100vh;
    }

    .left-side, .right-side {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .left-side {
        background-color: white;
    }

        .left-side h1 {
            font-size: 4rem;
            font-weight: bold;
            color: black;
        }

    .right-side img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }
</style>
