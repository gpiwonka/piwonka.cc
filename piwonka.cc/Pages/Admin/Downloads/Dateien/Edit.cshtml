@page "{id:int}"
@model Piwonka.CC.Pages.Admin.Downloads.Dateien.EditModel
@{
    ViewData["Title"] = "Download-Datei bearbeiten";
}

<h1>Datei bearbeiten <small class="text-muted">@Model.AppName</small></h1>

<form method="post" class="mt-4">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="Datei.Id" />
    <input type="hidden" asp-for="Datei.DownloadAppId" />
    <input type="hidden" asp-for="Datei.ErstelltAm" />

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Datei.Plattform" class="form-label">Plattform</label>
            <input asp-for="Datei.Plattform" class="form-control" />
            <span asp-validation-for="Datei.Plattform" class="text-danger small"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Datei.Version" class="form-label">Version (optional)</label>
            <input asp-for="Datei.Version" class="form-control" />
            <span asp-validation-for="Datei.Version" class="text-danger small"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Datei.DateiPfad" class="form-label">Datei-Pfad / URL</label>
        <input asp-for="Datei.DateiPfad" class="form-control" />
        <div class="form-text">Pfad zur per FTP hochgeladenen Datei (relativ zur Website) oder vollständige URL.</div>
        <span asp-validation-for="Datei.DateiPfad" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Datei.Hinweis" class="form-label">Hinweis (optional)</label>
        <input asp-for="Datei.Hinweis" class="form-control" />
        <span asp-validation-for="Datei.Hinweis" class="text-danger small"></span>
    </div>

    <div class="row">
        <div class="col-md-3 mb-3">
            <label asp-for="Datei.Dateigroesse" class="form-label">Größe (optional)</label>
            <input asp-for="Datei.Dateigroesse" class="form-control" />
            <span asp-validation-for="Datei.Dateigroesse" class="text-danger small"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="Datei.VeroeffentlichtAm" class="form-label">Datum (optional)</label>
            <input asp-for="Datei.VeroeffentlichtAm" type="date" class="form-control" />
            <span asp-validation-for="Datei.VeroeffentlichtAm" class="text-danger small"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="Datei.Reihenfolge" class="form-label">Reihenfolge</label>
            <input asp-for="Datei.Reihenfolge" type="number" class="form-control" />
        </div>
        <div class="col-md-3 mb-3 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="Datei.Aktiv" class="form-check-input" type="checkbox" />
                <label asp-for="Datei.Aktiv" class="form-check-label">Aktiv</label>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Speichern</button>
    <a asp-page="../Index" class="btn btn-outline-secondary">Abbrechen</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
