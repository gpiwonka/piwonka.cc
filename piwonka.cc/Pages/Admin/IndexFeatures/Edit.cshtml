@page "{id:int}"
@model Piwonka.CC.Pages.Admin.IndexFeatures.EditModel
@{
    ViewData["Title"] = "Feature bearbeiten";
}

<h1>Feature bearbeiten</h1>

<form method="post" class="mt-4">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="Feature.Id" />
    <input type="hidden" asp-for="Feature.ErstelltAm" />

    <div class="mb-3">
        <label asp-for="Feature.Titel" class="form-label">Titel</label>
        <input asp-for="Feature.Titel" class="form-control" />
        <span asp-validation-for="Feature.Titel" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Feature.Beschreibung" class="form-label">Beschreibung</label>
        <textarea asp-for="Feature.Beschreibung" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Feature.Beschreibung" class="text-danger small"></span>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Feature.Link" class="form-label">Link (optional)</label>
            <input asp-for="Feature.Link" class="form-control" />
            <span asp-validation-for="Feature.Link" class="text-danger small"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Feature.Icon" class="form-label">Icon (FontAwesome-Klasse)</label>
            <input asp-for="Feature.Icon" class="form-control" />
            <span asp-validation-for="Feature.Icon" class="text-danger small"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="Feature.Reihenfolge" class="form-label">Reihenfolge</label>
            <input asp-for="Feature.Reihenfolge" type="number" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Feature.Language" class="form-label">Sprache</label>
            <select asp-for="Feature.Language" class="form-select">
                <option value="@((int)Piwonka.CC.Models.Language.DE)">Deutsch</option>
                <option value="@((int)Piwonka.CC.Models.Language.EN)">English</option>
            </select>
        </div>
        <div class="col-md-4 mb-3 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="Feature.Aktiv" class="form-check-input" type="checkbox" />
                <label asp-for="Feature.Aktiv" class="form-check-label">Aktiv</label>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Speichern</button>
    <a asp-page="./Index" class="btn btn-outline-secondary">Abbrechen</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
