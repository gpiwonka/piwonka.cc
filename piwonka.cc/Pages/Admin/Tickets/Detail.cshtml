@page "{id:int}"
@model Piwonka.CC.Pages.Admin.Tickets.DetailModel
@using Piwonka.CC.Models
@{
    ViewData["Title"] = $"Ticket #{Model.Ticket.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>
        Ticket #@Model.Ticket.Id
        @if (Model.Ticket.Typ == TicketTyp.Bug)
        {
            <span class="badge bg-danger ms-2"><i class="fas fa-bug me-1"></i>Bug</span>
        }
        else
        {
            <span class="badge bg-primary ms-2"><i class="fas fa-lightbulb me-1"></i>Feature</span>
        }
    </h1>
    <a asp-page="./Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Zurück zur Übersicht
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-header">
                <h2 class="h5 mb-0">@Model.Ticket.Titel</h2>
            </div>
            <div class="card-body">
                <p style="white-space: pre-wrap;">@Model.Ticket.Beschreibung</p>
            </div>
        </div>

        <form method="post" asp-page-handler="Update" asp-route-id="@Model.Ticket.Id">
            <input type="hidden" asp-for="Ticket.Id" />
            <input type="hidden" asp-for="Ticket.Typ" />
            <input type="hidden" asp-for="Ticket.Titel" />
            <input type="hidden" asp-for="Ticket.Beschreibung" />
            <input type="hidden" asp-for="Ticket.MelderName" />
            <input type="hidden" asp-for="Ticket.MelderEmail" />
            <input type="hidden" asp-for="Ticket.ErstelltAm" />

            <div class="card mb-3">
                <div class="card-header">
                    <h2 class="h6 mb-0">Status & Notiz</h2>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Ticket.Status" class="form-label">Status</label>
                        <select asp-for="Ticket.Status" class="form-select" asp-items="Html.GetEnumSelectList<TicketStatus>()"></select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Ticket.AdminNotiz" class="form-label">Interne Notiz</label>
                        <textarea asp-for="Ticket.AdminNotiz" class="form-control" rows="4" placeholder="Nur intern sichtbar"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Speichern</button>
                </div>
            </div>
        </form>

        <form method="post" asp-page-handler="Delete" asp-route-id="@Model.Ticket.Id"
              onsubmit="return confirm('Ticket wirklich löschen?');">
            <button type="submit" class="btn btn-outline-danger">
                <i class="fas fa-trash me-2"></i>Ticket löschen
            </button>
        </form>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h2 class="h6 mb-0">Meta</h2>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5">Melder</dt>
                    <dd class="col-7">@Model.Ticket.MelderName</dd>

                    <dt class="col-5">E-Mail</dt>
                    <dd class="col-7"><a href="mailto:@Model.Ticket.MelderEmail">@Model.Ticket.MelderEmail</a></dd>

                    <dt class="col-5">Erstellt</dt>
                    <dd class="col-7">@Model.Ticket.ErstelltAm.ToString("dd.MM.yyyy HH:mm")</dd>

                    <dt class="col-5">IP</dt>
                    <dd class="col-7"><code>@(Model.Ticket.IpAdresse ?? "—")</code></dd>
                </dl>
            </div>
        </div>
    </div>
</div>
