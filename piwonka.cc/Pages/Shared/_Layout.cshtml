<!-- Pages/Shared/_Layout.cshtml (UPDATE mit Suchbox und Sprachauswahl) -->
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Piwonka.CC</title>

    @if (ViewData["MetaDescription"] != null)
    {
        <meta name="description" content="@ViewData["MetaDescription"]" />
    }

    @if (ViewData["MetaKeywords"] != null)
    {
        <meta name="keywords" content="@ViewData["MetaKeywords"]" />
    }

    <meta property="og:title" content="@ViewData["Title"] - Piwonka.CC" />
    @if (ViewData["MetaDescription"] != null)
    {
        <meta property="og:description" content="@ViewData["MetaDescription"]" />
    }
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@Context.Request.Scheme://@Context.Request.Host@Context.Request.Path" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Piwonka.CC.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <!-- TinyMCE CDN -->
    <script src="https://cdn.tiny.cloud/1/no-api-key/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-page="/Index">
                    piwonka.cc
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <!-- Hauptmenü -->
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">
                                Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Blog/Index">
                                Blog
                            </a>
                        </li>

                        <!-- Hierarchisches Menü -->
                        @await Component.InvokeAsync("MainMenu")

                    </ul>

                    <!-- Rechte Seite: Suche, Sprache, Admin -->
                    <div class="d-flex align-items-center">
                        <!-- Suchbox -->
                        <div class="me-3">
                            @await Component.InvokeAsync("SearchBox")
                        </div>

                        <!-- Sprachauswahl -->
                        <div class="me-3">
                            @await Component.InvokeAsync("LanguageSwitcher")
                        </div>

                        <!-- Admin-Bereich -->
                        <div class="dropdown">

                            <a class="dropdown-item" asp-page="/Admin/Index">
                                Admin
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container">

            <div class="row">
                <div class="col-md-6">
                    <p class="small mb-0">
                        &copy; @DateTime.Now.Year - piwonka.cc - Baustelle seit 2000
                        <a asp-area="" asp-page="/Privacy" class="text-decoration-none">Privacy</a>
                    </p>
                </div>
                <div class="col-md-6 text-end">
                    <p class="small mb-0">
                        made with ASP.NET Core
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>