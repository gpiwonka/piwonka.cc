@page
@model Piwonka.CC.Pages.Tools.DeadlockAnalyzerModel
@inject SiteSettings Site
@{
    ViewData["Title"] = "SQL Deadlock Analyzer";
    ViewData["MetaDescription"] = "SQL Server Deadlock-Graphs analysieren lassen — Ursachen verstehen, Lösungen erhalten.";
}

<div class="container py-4">
    <div class="row">
        <div class="col-lg-10 mx-auto">
            <h1><i class="fas fa-lock me-2"></i>Deadlock Analyzer</h1>
            <p class="lead">SQL Server Deadlock-Graphs analysieren — Ursachen und Lösungen erhalten.</p>

            <div class="alert alert-info d-flex align-items-start" role="alert">
                <i class="fas fa-gift me-3 mt-1 fa-lg"></i>
                <div>
                    <strong>Dieses Tool ist kostenlos</strong> und funktioniert, solange das Token-Budget reicht.
                    Wenn dir das Tool hilft, freue ich mich über einen
                    <a href="@Site.CoffeeUrl" target="_blank" class="alert-link"><i class="fas fa-coffee me-1"></i>Kaffee</a>.
                </div>
            </div>

            @if (Model.HasError)
            {
                <div class="alert alert-danger" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i>@Model.ErrorMessage
                </div>
            }

            <div class="card mb-4">
                <div class="card-header">
                    <h2 class="h5 mb-0"><i class="fas fa-keyboard me-2"></i>Deadlock-Graph einfügen</h2>
                </div>
                <div class="card-body">
                    <form method="post" id="toolForm">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Sprache / Language</label>
                            <div class="d-flex gap-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="Language" id="langDe" value="de"
                                           checked="@(Model.Language == "de")">
                                    <label class="form-check-label" for="langDe">Deutsch</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="Language" id="langEn" value="en"
                                           checked="@(Model.Language == "en")">
                                    <label class="form-check-label" for="langEn">English</label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="deadlockXml" class="form-label fw-bold">
                                Deadlock-Graph (XML)
                            </label>
                            <textarea id="deadlockXml" name="DeadlockXml" class="form-control font-monospace"
                                      rows="14" placeholder="&lt;deadlock&gt;&#10;  &lt;victim-list&gt;&#10;    &lt;victimProcess id=&quot;process1&quot; /&gt;&#10;  &lt;/victim-list&gt;&#10;  &lt;process-list&gt;&#10;    ...&#10;  &lt;/process-list&gt;&#10;  &lt;resource-list&gt;&#10;    ...&#10;  &lt;/resource-list&gt;&#10;&lt;/deadlock&gt;"
                                      style="font-size: 0.85rem;">@Model.DeadlockXml</textarea>
                        </div>

                        <button type="submit" class="btn btn-primary" id="submitBtn">
                            <i class="fas fa-magic me-2"></i>Analysieren
                        </button>
                        <span id="loadingIndicator" class="ms-3 d-none">
                            <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
                            <span class="text-muted ms-1">Claude analysiert...</span>
                        </span>
                    </form>
                </div>
            </div>

            @if (Model.AnalysisComplete && Model.AnalysisResult != null)
            {
                <div class="card mb-4">
                    <div class="card-header bg-success bg-opacity-10 d-flex justify-content-between align-items-center">
                        <h2 class="h5 mb-0"><i class="fas fa-lightbulb me-2 text-success"></i>Deadlock-Analyse</h2>
                        <form method="post" asp-page-handler="Share" class="d-inline">
                            <input type="hidden" name="DeadlockXml" value="@Model.DeadlockXml" />
                            <input type="hidden" name="AnalysisResult" value="@Model.AnalysisResult" />
                            <input type="hidden" name="Language" value="@Model.Language" />
                            <button type="submit" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-share-alt me-1"></i>Teilen
                            </button>
                        </form>
                    </div>
                    <div class="card-body" id="analysisResult">
                        @Html.Raw(ConvertMarkdownToHtml(Model.AnalysisResult))
                    </div>
                </div>
            }

            <div class="card bg-light">
                <div class="card-body">
                    <h5><i class="fas fa-info-circle me-2"></i>Tipps</h5>
                    <ul class="mb-0 small">
                        <li>Deadlock-Graph XML findet man im SQL Server Error Log oder über Extended Events.</li>
                        <li>In SSMS: Management &rarr; Extended Events &rarr; system_health &rarr; nach <code>xml_deadlock_report</code> filtern.</li>
                        <li>Auch der Textoutput von <code>DBCC TRACEON(1222, -1)</code> wird unterstützt.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_ToolStyles")

@section Scripts {
    <script>
        document.getElementById('toolForm').addEventListener('submit', function () {
            var input = document.getElementById('deadlockXml').value.trim();
            if (input.length > 0) {
                document.getElementById('submitBtn').disabled = true;
                document.getElementById('loadingIndicator').classList.remove('d-none');
            }
        });
    </script>
}

@functions {
    string ConvertMarkdownToHtml(string markdown)
    {
        return Piwonka.CC.Helpers.MarkdownHelper.ToHtml(markdown);
    }
}
