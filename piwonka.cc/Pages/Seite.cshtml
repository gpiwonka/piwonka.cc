@page "/seite/{slug}"
@model Piwonka.CC.Pages.SeiteModel
@inject SiteSettings Site
@{
    ViewData["Title"] = Model.Seite.Titel;
    if (!string.IsNullOrEmpty(Model.Seite.MetaDescription))
    {
        ViewData["MetaDescription"] = Model.Seite.MetaDescription;
    }
    if (!string.IsNullOrEmpty(Model.Seite.MetaKeywords))
    {
        ViewData["MetaKeywords"] = Model.Seite.MetaKeywords;
    }
    if (string.Equals(Model.Seite.JsonLdTyp, "Article", StringComparison.OrdinalIgnoreCase))
    {
        ViewData["OgType"] = "article";
    }
}

@if (Model.Seite.Template == "Kontakt")
{
    <!-- Kontakt-Template -->
    <div class="row">
        <div class="col-md-8">
            <h1>@Model.Seite.Titel</h1>

            <div class="content">
                @Html.Raw(Model.Seite.Inhalt)
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5>Kontakt-Informationen</h5>
                </div>
                <div class="card-body">
                    <p><strong>E-Mail:</strong> @Site.ContactEmail</p>
                    <p>
                        <strong>Adresse:</strong><br>
                        @Site.Street<br>
                        @Site.Zip @Site.City, @Site.CountryName
                    </p>
                </div>
            </div>

            <!-- Kontakt-Formular -->
            <div class="card mt-4">
                <div class="card-header">
                    <h5>Nachricht senden</h5>
                </div>
                <div class="card-body">
                    <form>
                        <div class="mb-3">
                            <label for="contactName" class="form-label">Name</label>
                            <input type="text" class="form-control" id="contactName" required>
                        </div>
                        <div class="mb-3">
                            <label for="contactEmail" class="form-label">E-Mail</label>
                            <input type="email" class="form-control" id="contactEmail" required>
                        </div>
                        <div class="mb-3">
                            <label for="contactMessage" class="form-label">Nachricht</label>
                            <textarea class="form-control" id="contactMessage" rows="4" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Senden</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
else if (Model.Seite.Template == "Vollbreite")
{
    <!-- Vollbreite-Template -->
    <div class="row">
        <div class="col-12">
            <h1 class="text-center mb-4">@Model.Seite.Titel</h1>

            <div class="content">
                @Html.Raw(Model.Seite.Inhalt)
            </div>
        </div>
    </div>
}
else
{
    <!-- Standard-Template -->
    <div class="row">
        <div class="col-md-8">
            <h1>@Model.Seite.Titel</h1>

            <div class="content">
                @Html.Raw(Model.Seite.Inhalt)
            </div>

            @if (Model.Seite.BearbeitetAm.HasValue)
            {
                <div class="mt-4">
                    <small class="text-muted">
                        Zuletzt bearbeitet: @Model.Seite.BearbeitetAm.Value.ToString("dd.MM.yyyy HH:mm")
                    </small>
                </div>
            }
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5>Navigation</h5>
                </div>
                <div class="card-body">
                    @await Component.InvokeAsync("MenuSeiten")
                </div>
            </div>
        </div>
    </div>
}

@section JsonLd {
    @if (!string.IsNullOrWhiteSpace(Model.Seite.JsonLdTyp))
    {
        var allowedTypes = new[] { "WebPage", "Article", "AboutPage", "ContactPage" };
        var schemaType = allowedTypes.Contains(Model.Seite.JsonLdTyp, StringComparer.OrdinalIgnoreCase)
            ? Model.Seite.JsonLdTyp
            : "WebPage";

        var siteRoot = $"{HttpContext.Request.Scheme}://{HttpContext.Request.Host}";
        var pageUrl = $"{siteRoot}/seite/{Model.Seite.Slug}";
        var langCode = Model.Seite.GetLanguageCode();

        var jsonName = System.Web.HttpUtility.JavaScriptStringEncode(Model.Seite.Titel ?? "");
        var jsonDesc = System.Web.HttpUtility.JavaScriptStringEncode(Model.Seite.MetaDescription ?? "");
        var jsonKeywords = System.Web.HttpUtility.JavaScriptStringEncode(Model.Seite.MetaKeywords ?? "");
        var datePublished = Model.Seite.ErstelltAm.ToString("yyyy-MM-dd");
        var dateModified = (Model.Seite.BearbeitetAm ?? Model.Seite.ErstelltAm).ToString("yyyy-MM-dd");
        var isArticle = string.Equals(schemaType, "Article", StringComparison.OrdinalIgnoreCase);

        <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@type": "@schemaType",
          @if (isArticle)
          {
              <text>"headline": "@Html.Raw(jsonName)",</text>
          }
          else
          {
              <text>"name": "@Html.Raw(jsonName)",</text>
          }
          @if (!string.IsNullOrWhiteSpace(Model.Seite.MetaDescription))
          {
              <text>"description": "@Html.Raw(jsonDesc)",</text>
          }
          @if (!string.IsNullOrWhiteSpace(Model.Seite.MetaKeywords))
          {
              <text>"keywords": "@Html.Raw(jsonKeywords)",</text>
          }
          "url": "@pageUrl",
          "inLanguage": "@langCode",
          "datePublished": "@datePublished",
          "dateModified": "@dateModified",
          @if (isArticle)
          {
              <text>
              "mainEntityOfPage": { "@@type": "WebPage", "@@id": "@pageUrl" },
              "author": { "@@type": "Person", "name": "@Site.Author", "url": "@siteRoot" },
              "publisher": { "@@type": "Person", "name": "@Site.Author", "url": "@siteRoot" },
              </text>
          }
          "isPartOf": { "@@type": "WebSite", "name": "@Site.Name", "url": "@siteRoot" }
        }
        </script>
    }
}